{
  "name": "@seatlayer/react",
  "version": "0.25.0",
  "description": "React component for the SeatLayer embed SDK — render an interactive seat picker and hold seats.",
  "license": "MIT",
  "homepage": "https://docs.seatlayer.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seatlayer/seatlayer-sdk.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/seatlayer/seatlayer-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "seating",
    "seat-map",
    "seatlayer",
    "react",
    "ticketing"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@seatlayer/js": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0"
  }
}
