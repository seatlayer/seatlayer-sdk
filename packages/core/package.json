{
  "name": "@seatlayer/core",
  "version": "0.29.0",
  "description": "Framework-agnostic seat-rendering engine (Konva) shared by the SeatLayer SDKs.",
  "license": "MIT",
  "homepage": "https://docs.seatlayer.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seatlayer/seatlayer-sdk.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/seatlayer/seatlayer-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "view3d": [
        "./dist/view3d/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./view3d": {
      "import": {
        "types": "./dist/view3d/index.d.ts",
        "default": "./dist/view3d/index.js"
      },
      "require": {
        "types": "./dist/view3d/index.d.cts",
        "default": "./dist/view3d/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "seating",
    "seat-map",
    "seatlayer",
    "konva",
    "canvas",
    "reserved-seating"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "earcut": "^3.2.3",
    "konva": "^10.3.0",
    "ogl": "^1.0.11"
  },
  "devDependencies": {
    "@types/earcut": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0"
  }
}
