{
  "name": "@seatlayer/core",
  "version": "0.1.0",
  "description": "Framework-agnostic seat-rendering engine (Konva) shared by the SeatLayer SDKs.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "konva": "^10.3.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.0"
  }
}
