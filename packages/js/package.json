{
  "name": "@seatlayer/js",
  "version": "0.28.2",
  "description": "The SeatLayer embed SDK — render an interactive seat picker and hold seats from the browser. Works in any JS framework.",
  "license": "MIT",
  "homepage": "https://docs.seatlayer.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seatlayer/seatlayer-sdk.git",
    "directory": "packages/js"
  },
  "bugs": {
    "url": "https://github.com/seatlayer/seatlayer-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "seating",
    "seat-map",
    "seatlayer",
    "ticketing",
    "reserved-seating"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@seatlayer/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.0"
  }
}
