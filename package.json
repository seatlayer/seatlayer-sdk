{
  "name": "seatlayer-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "SeatLayer SDK monorepo — the framework-agnostic core plus per-framework wrappers.",
  "type": "module",
  "scripts": {
    "sync:core": "node scripts/sync-core.mjs",
    "check:sync": "node scripts/sync-core.mjs --check",
    "check:version": "node scripts/check-release-version.mjs",
    "build": "pnpm -r build",
    "test": "vitest run",
    "lint:packages": "publint packages/core && publint packages/js && publint packages/react && attw --pack packages/core && attw --pack packages/js && attw --pack packages/react",
    "build:cdn": "vite build --config cdn/vite.config.ts && node scripts/finalize-cdn.mjs",
    "typecheck": "pnpm -r typecheck && tsc -p cdn/tsconfig.json",
    "verify:cdn": "node scripts/verify-cdn-build.mjs",
    "verify:cdn:remote": "node scripts/verify-cdn-deployment.mjs",
    "cdn:upload:immutable": "node scripts/upload-cdn.mjs immutable",
    "cdn:promote": "node scripts/upload-cdn.mjs index",
    "cdn:migrate:legacy": "node scripts/migrate-legacy-cdn.mjs",
    "publish:packages": "node scripts/publish-packages.mjs",
    "clean": "pnpm -r exec rm -rf dist",
    "release:prep": "pnpm sync:core && pnpm check:sync && pnpm check:version && pnpm build && pnpm typecheck && pnpm test && pnpm lint:packages && pnpm build:cdn && pnpm verify:cdn",
    "sync:widget": "node scripts/sync-widget.mjs",
    "check:widget-sync": "node scripts/sync-widget.mjs --check"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "jsdom": "^26.1.0",
    "publint": "0.3.21",
    "typescript": "^5.9.0",
    "vite": "^8.1.4",
    "vitest": "~4.1.10",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.10.0"
}
